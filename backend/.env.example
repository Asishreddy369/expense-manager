# Copy this file to backend/.env and replace the placeholder values.
# For Gmail SMTP, use your Gmail address and a Google App Password.

ALLOWED_HOSTS=127.0.0.1,localhost

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=yourgmail@gmail.com
EMAIL_HOST_PASSWORD=your_16_digit_app_password
DEFAULT_FROM_EMAIL=noreply@vvkr.com

COMMON_LOGIN_OTP=234560
COMMON_LOGIN_PASSWORD=234560
